{
  "include": ["src", "tests"],
  "exclude": ["**/__pycache__", ".venv", "venv"],
  "typeCheckingMode": "standard",
  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.12",
  "venvPath": ".",
  "venv": "venv",
  "extraPaths": [
    "./src",
    "./src/infrastructure/django"
  ]
}
